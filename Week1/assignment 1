        "to swap two numbers without a third variable"
      ],
      "metadata": {
        "id": "oYI34K4vef8j"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "a = int(input(\"Enter first number: \"))\n",
        "b = int(input(\"Enter second number: \"))\n",
        "print(\"Before swap -> a:\", a, \"b:\", b)\n",
        "a, b = b, a\n",
        "print(\"After swap  -> a:\", a, \"b:\", b)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
