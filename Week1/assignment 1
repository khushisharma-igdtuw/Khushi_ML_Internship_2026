        "student report program -"
      ],
      "metadata": {
        "id": "_Fzc1QPzepgf"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ---- Student Report Program ----\n",
        "\n",
        "# Taking student details as input\n",
        "name = input(\"Enter student name: \")\n",
        "roll_no = input(\"Enter roll number: \")\n",
        "\n",
        "# Storing marks in variables\n",
        "marks_english  = float(input(\"Enter marks in English: \"))\n",
        "marks_math     = float(input(\"Enter marks in Maths: \"))\n",
        "marks_science  = float(input(\"Enter marks in Science: \"))\n",
        "marks_hindi    = float(input(\"Enter marks in Hindi: \"))\n",
        "marks_computer = float(input(\"Enter marks in Computer: \"))\n",
        "\n",
        "# Calculating total and percentage\n",
        "total      = marks_english + marks_math + marks_science + marks_hindi + marks_computer\n",
        "percentage = (total / 500) * 100\n",
        "\n",
        "# Displaying the report\n",
        "print(\"\\n---------- Student Report ----------\")\n",
        "print(\"Name      :\", name)\n",
        "print(\"Roll No.  :\", roll_no)\n",
        "print(\"English   :\", marks_english)\n",
        "print(\"Maths     :\", marks_math)\n",
        "print(\"Science   :\", marks_science)\n",
        "print(\"Hindi     :\", marks_hindi)\n",
        "print(\"Computer  :\", marks_computer)\n",
        "print(\"Total     :\", total, \"/ 500\")\n",
        "print(\"Percentage:\", percentage, \"%\")\n",
        "print(\"------------------------------------\")"
      ],
